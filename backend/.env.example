# Backend (NestJS) — copie para .env e preencha. NUNCA commitar o .env real.
# Segredos: gere com `openssl rand -hex 32` (ou similar).

NODE_ENV=production
APP_PORT=3001
API_PREFIX=api/v1

# Postgres gerenciado (Neon/Supabase/Railway) ou container na VPS.
# Use sslmode=require em provedores gerenciados.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/evosec?schema=public

# JWT (access curto + refresh rotation). Troque os segredos!
JWT_SECRET=troque-por-hex-32-bytes
JWT_REFRESH_SECRET=troque-por-outro-hex-32-bytes
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=30d

# Token de serviço usado pelo n8n (header x-service-token) p/ chamar a API.
SERVICE_TOKEN=troque-por-hex-32-bytes

# Chave de criptografia de dados sensíveis (32 bytes hex).
ENCRYPTION_KEY=troque-por-hex-32-bytes

# Seed do owner (dev). Em produção troque a senha após o primeiro login.
SEED_OWNER_PASSWORD=troque-em-producao
