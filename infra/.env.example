# ───────────────────────── evo-sec (Nina) — exemplo de variáveis ─────────────────────────
# Copie para .env e preencha. NUNCA commite o .env real.

# ── Postgres ──
POSTGRES_USER=evosec
POSTGRES_PASSWORD=change-me
POSTGRES_DB=evosec
DATABASE_URL=postgresql://evosec:change-me@postgres:5432/evosec?schema=public

# ── Redis ──
REDIS_URL=redis://:change-me@redis:6379

# ── Backend ──
NODE_ENV=development
APP_NAME=evo-sec-backend
APP_PORT=3001
API_PREFIX=/api/v1
JWT_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
ENCRYPTION_KEY=change-me-32-chars-exactly-aes256   # 32 chars p/ AES-256-GCM
SERVICE_TOKEN=change-me-internal-token             # token de serviço usado pelo n8n

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ── OpenRouter (LLM) ──
OPENROUTER_API_KEY=change-me
OPENROUTER_MODEL_FRACO=nvidia/nemotron-3.5-content-safety:free
OPENROUTER_MODEL_INTER=qwen/qwen3.7-max
OPENROUTER_MODEL_PREMIUM=anthropic/claude-sonnet-4.6

# ── Evolution API (WhatsApp) ──
EVOLUTION_API_URL=https://evolution.exemplo.cloud
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=nina
EVOLUTION_WEBHOOK_HMAC_SECRET=change-me

# ── Mídia (MinIO/S3) ──
S3_ENDPOINT=http://minio:9000
S3_BUCKET=evosec-media
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me

# ── Transcrição / Visão (multimodal) — definir provider na Sprint 1 ──
TRANSCRIBE_PROVIDER=openrouter
VISION_PROVIDER=openrouter

# ── n8n ──
N8N_WEBHOOK_URL=https://n8n.exemplo.cloud
